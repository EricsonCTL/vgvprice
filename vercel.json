{
  "headers": [
    {
      "source": "/(.*\\.pdf)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, HEAD, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Content-Disposition", "value": "inline" }
      ]
    }
  ]
}
